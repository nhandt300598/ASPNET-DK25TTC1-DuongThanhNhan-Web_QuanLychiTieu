@model List<QuanLyChiTieu.Models.TaiKhoanViewModel>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <h2 class="mb-0"><i class="fa-solid fa-users-gear me-2"></i>Quản lý người dùng</h2>

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary fw-bold shadow-sm">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại trang chủ
    </a>
</div>
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Tên tài khoản</th>
                    <th>Email khôi phục</th>

                    <th>Hoạt động gần nhất</th>
                    <th>Mức độ (30 ngày qua)</th>

                    <th>Trạng thái</th>
                    <th class="text-center" style="width: 300px;">Thao tác quản trị</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@user.TaiKhoan</td>

                        <td class="text-muted">
                            @if (string.IsNullOrEmpty(user.Email))
                            {
                                <span class="text-warning small"><i class="fa-solid fa-triangle-exclamation me-1"></i>Chưa cập nhật</span>
                            }
                            else
                            {
                                <span class="text-dark fw-bold">@user.Email</span>
                            }
                        </td>

                        <td>
                            @if (user.LanDangNhapCuoi.HasValue)
                            {
                                <span class="small fw-bold text-dark">@user.LanDangNhapCuoi.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            }
                            else
                            {
                                <span class="small text-muted fst-italic">Chưa từng đăng nhập</span>
                            }
                        </td>

                        <td>
                            @if (user.SoGiaoDich30Ngay == 0)
                            {
                                <span class="badge bg-secondary fw-normal">Không hoạt động</span>
                            }
                            else if (user.SoGiaoDich30Ngay <= 5)
                            {
                                <span class="badge bg-warning text-dark fw-bold" title="Đã gõ @user.SoGiaoDich30Ngay giao dịch">
                                    <i class="fa-solid fa-battery-quarter me-1"></i>Hoạt động ít
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark fw-bold" title="Đã gõ @user.SoGiaoDich30Ngay giao dịch">
                                    <i class="fa-solid fa-fire me-1 text-danger"></i>Thường xuyên
                                </span>
                            }
                        </td>

                        <td>
                            @if (user.TrangThai)
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Bị tạm ngưng</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-primary me-1" onclick="openPasswordModal('@user.TaiKhoan')">
                                <i class="fa-solid fa-key"></i> Đổi Pass
                            </button>

                            <a asp-action="ToggleStatus" asp-route-id="@user.TaiKhoan" asp-route-status="@user.TrangThai"
                               class="btn btn-sm @(user.TrangThai ? "btn-danger" : "btn-success")">
                                <i class="fa-solid @(user.TrangThai ? "fa-lock" : "fa-unlock")"></i>
                                @(user.TrangThai ? "Khóa nick" : "Mở khóa")
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="passwordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ResetPassword" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Cập nhật mật khẩu</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="username" id="modalUsername" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tài khoản:</label>
                        <input type="text" id="displayUsername" class="form-control" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới:</label>
                        <input type="password" name="newPassword" class="form-control" required placeholder="Nhập mật khẩu mới..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu mật khẩu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.12/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.12/dist/sweetalert2.all.min.js"></script>

<script>
    function openPasswordModal(username) {
        document.getElementById('modalUsername').value = username;
        document.getElementById('displayUsername').value = username;
        var myModal = new bootstrap.Modal(document.getElementById('passwordModal'));
        myModal.show();
    }
 
    @if (TempData["SuccessMessage"] != null)
    {
        <text>
        Swal.fire({
            title: 'Thành công!',
            text: '@Html.Raw(TempData["SuccessMessage"])',
            icon: 'success',
            confirmButtonColor: '#198754'
        });
        </text>
    }
</script>