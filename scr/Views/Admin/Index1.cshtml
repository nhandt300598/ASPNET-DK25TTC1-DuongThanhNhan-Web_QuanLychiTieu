@model List<QuanLyChiTieu.Models.NhatKyHeThong>
@{
    ViewData["Title"] = "Nhật ký hệ thống";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <div>
        <h2 class="mb-0 fw-bold"><i class="fa-solid fa-clock-rotate-left me-2 text-secondary"></i>Nhật ký hoạt động</h2>
        <p class="text-muted small mb-0">Truy vết toàn bộ thao tác của user và admin để dò lỗi & bảo mật.</p>
    </div>
    <a asp-action="Report" class="btn btn-secondary shadow-sm">
        <i class="fa-solid fa-arrow-left me-1"></i> Về trang quản trị
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase fs-7 text-muted">
                    <tr>
                        <th class="ps-3" style="width: 15%;">Thời gian</th>
                        <th style="width: 15%;">Tài khoản</th>
                        <th style="width: 15%;">Hành động</th>
                        <th style="width: 45%;">Chi tiết</th>
                        <th class="pe-3 text-end" style="width: 10%;">Địa chỉ IP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Chưa có bản ghi nhật ký nào.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fs-7 text-muted">@item.ThoiGianTao.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td class="fw-bold">@item.TaiKhoan</td>
                                <td>
                                    <span class="badge bg-info text-dark">@item.HanhDong</span>
                                </td>
                                <td class="text-secondary fs-7">@item.ChiTiet</td>
                                <td class="pe-3 text-end fs-7 text-muted">@item.DiaChiIP</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>