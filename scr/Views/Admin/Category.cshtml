@model List<QuanLyChiTieu.Models.DanhMuc>
@{
    ViewData["Title"] = "Quản lý danh mục hệ thống";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <h2 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-folder-tree me-2 text-primary"></i>Cấu Hình Danh Mục Hệ Thống</h2>
    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary fw-bold shadow-sm">
        <i class="fa-solid fa-arrow-left me-1"></i> Về trang Quản lý User
    </a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-bold py-3">
                <i class="fa-solid fa-plus me-1"></i> THÊM DANH MỤC CHUNG
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateCategory" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Tên danh mục</label>
                        <input type="text" name="tenDanhMuc" class="form-control" placeholder="Ví dụ: Tiền điện, Đầu tư..." required autocomplete="off" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold small">Phân loại</label>
                        <select name="loaiGiaoDich" class="form-select fw-bold" required>
                            <option value="Chi" class="text-danger">🔴 KHOẢN CHI TIÊU (Chi ra)</option>
                            <option value="Thu" class="text-success">🟢 KHOẢN THU NHẬP (Thu về)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Lưu
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white fw-bold py-3">
                <i class="fa-solid fa-list me-1"></i> DANH SÁCH DANH MỤC HIỆN CÓ
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 60px;">ID</th>
                            <th>Tên danh mục hiển thị</th>
                            <th>Loại hình</th>
                            <th class="text-center" style="width: 120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@item.Id</td>
                                <td class="fw-bold text-dark">@item.TenDanhMuc</td>
                                <td>
                                    @if (item.LoaiGiaoDich == "Chi")
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-1 fw-bold">Khoản Chi</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1 fw-bold">Khoản Thu</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <form asp-action="DeleteCategory" method="post" id="form-delete-@item.Id">
                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="button" class="btn btn-link text-danger p-0 m-0 text-decoration-none fw-bold small"
                                                onclick="xacNhanXoa('@item.Id', '@item.TenDanhMuc')">
                                            <i class="fa-solid fa-trash-can me-1"></i>Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.12/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.12/dist/sweetalert2.all.min.js"></script>
<script>
    @if (TempData["ErrorMessage"] != null) { <text>Swal.fire({ title: 'Không hợp lệ!', text: '@Html.Raw(TempData["ErrorMessage"])', icon: 'error', confirmButtonColor: '#dc3545' });</text> }
    @if (TempData["SuccessMessage"] != null) { <text>Swal.fire({ title: 'Thành công!', text: '@Html.Raw(TempData["SuccessMessage"])', icon: 'success', confirmButtonColor: '#0d6efd' });</text> }
</script>

<script> 
    function xacNhanXoa(id, tenDanhMuc) {
        Swal.fire({
            title: 'Bạn có chắc chắn muốn xóa?',
            text: `Danh mục [${tenDanhMuc}] sẽ bị biến mất khỏi hệ thống và TẤT CẢ tài khoản người dùng khác!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',  
            cancelButtonColor: '#6c757d',  
            confirmButtonText: '<i class="fa-solid fa-trash-can me-1"></i> Vẫn muốn xóa',
            cancelButtonText: 'Hủy bỏ',
            customClass: {
                popup: 'animate__animated animate__headShake' 
            }
        }).then((result) => { 
            if (result.isConfirmed) { 
                document.getElementById('form-delete' + '-' + id).submit();
            }
        });
    } 
</script>