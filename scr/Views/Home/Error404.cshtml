@using Microsoft.AspNetCore.Diagnostics
@{
    ViewData["Title"] = "404 - Không tìm thấy trang";
    Layout = "_Layout";

    // MA THUẬT: Móc cái "ngăn kéo bí mật" của ASP.NET ra để bóc đường dẫn gốc
    var statusCodeFeature = Context.Features.Get<IStatusCodeReExecuteFeature>();
    string originalUrl = statusCodeFeature?.OriginalPath ?? Context.Request.Path.Value;
}

<div class="container text-center my-5 py-5 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="mb-4 text-warning">
                <svg xmlns="http://www.w3.org/2000/svg" width="130" height="130" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                    <path d="M4.285 12.433a.5.5 0 0 0 .683-.183A3.498 3.498 0 0 1 8 10.5c1.295 0 2.426.703 3.032 1.75a.5.5 0 0 0 .866-.5A4.498 4.498 0 0 0 8 9.5a4.5 4.5 0 0 0-3.898 2.25.5.5 0 0 0 .183.683zM7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5zm4 0c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5z" />
                </svg>
            </div>

            <h1 class="display-1 fw-bold text-primary" style="font-size: 5.5rem;">404</h1>
            <h3 class="fw-bold text-dark mb-3">Rất tiếc... Trang bạn tìm không tồn tại!</h3>

            <p class="text-muted mb-4 fs-5">
                Hệ thống không tìm thấy chức năng nào có địa chỉ <span class="text-danger fw-bold">@originalUrl</span>. Vui lòng kiểm tra lại chính tả trên thanh địa chỉ!
            </p>

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg fw-bold shadow-sm px-4 py-2 text-white">
                <i class="fa-solid fa-house me-2"></i> Quay lại màn hình chính
            </a>

        </div>
    </div>
</div>