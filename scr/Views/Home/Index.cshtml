@model IEnumerable<QuanLyChiTieu.Models.GiaoDich>

@{
    ViewData["Title"] = "Quản lý chi tiêu";
}

<style>
    .btn-fintech {
        background-color: #e0f2fe;
        color: #0284c7;
        border: 1px solid #bae6fd;
        border-radius: 50rem !important;
        padding: 0.35rem 0.95rem !important;
        font-size: 0.85rem;
        transition: all 0.2s ease-in-out;
    }

        .btn-fintech:hover {
            background-color: #0284c7;
            color: #ffffff;
            border-color: #0284c7;
            transform: translateY(-1.5px);
            box-shadow: 0 4px 10px rgba(2, 132, 199, 0.25);
        }

    .metric-card {
        border-radius: 1rem;
        transition: transform 0.2s ease;
    }

        .metric-card:hover {
            transform: translateY(-3px);
        }

    .bg-soft-success {
        background-color: #f0fdf4;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .bg-soft-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .bg-premium-dark {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: #f8fafc;
        border: 1px solid #334155;
    }
</style>

<div class="d-flex justify-content-between align-items-center sticky-top py-3 mb-3"
     style="top: 0; z-index: 1020; background-color: rgba(233, 239, 246, 0.85); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(0,0,0,0.05);">

    <h2 class="mb-0 fw-bold">Tổng quan</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger fw-bold mb-0">@TempData["ErrorMessage"]</div>
    }
<div>
    <a asp-action="ExportExcel" class="btn btn-success shadow-sm me-3">
        <i class="fa-solid fa-file-excel me-1"></i> Xuất báo cáo Excel
    </a>
    <a asp-controller="DanhMuc" asp-action="Index" class="btn btn-outline-primary shadow-sm me-2 bg-white">
        <i class="fa-solid fa-tags me-1"></i> Cấu hình Danh mục
    </a>
    <button type="button" class="btn btn-primary shadow-sm fw-bold" onclick="moPopupThemGiaoDich()">
        <i class="fa-solid fa-plus me-1"></i> Thêm giao dịch mới
    </button>
</div>
</div>

@{
    decimal tThu = ViewBag.TongThu ?? 0;
    decimal tChi = ViewBag.TongChi ?? 0;
    decimal soDu = tThu - tChi;
}
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card metric-card bg-soft-success h-100 shadow-sm">
            <div class="card-body p-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">Tổng tiền Thu về</div>
                    <h4 class="mb-0 fw-bold">@tThu.ToString("N0") <span class="fs-6 fw-normal text-muted">VNĐ</span></h4>
                </div>
                <div class="p-3 rounded-circle bg-success bg-opacity-10 text-success fs-4">
                    <i class="fa-solid fa-arrow-trend-up"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card metric-card bg-soft-danger h-100 shadow-sm">
            <div class="card-body p-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">Tổng tiền Chi ra</div>
                    <h4 class="mb-0 fw-bold">@tChi.ToString("N0") <span class="fs-6 fw-normal text-muted">VNĐ</span></h4>
                </div>
                <div class="p-3 rounded-circle bg-danger bg-opacity-10 text-danger fs-4">
                    <i class="fa-solid fa-arrow-trend-down"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card metric-card bg-premium-dark h-100 shadow-sm">
            <div class="card-body p-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1 text-light">Số dư còn lại</div>
                    <h4 class="mb-0 fw-bold" style="color: #38bdf8;">@soDu.ToString("N0") <span class="fs-6 fw-normal text-light">VNĐ</span></h4>
                </div>
                <div class="p-3 rounded-circle bg-primary bg-opacity-20 text-info fs-4">
                    <i class="fa-solid fa-wallet"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4 g-3">
    <div class="col-md-4">
        <div class="card shadow h-100 border-0">
            <div class="card-header bg-dark text-white">
                <h6 class="mb-0">Tỷ lệ Thu / Chi</h6>
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <div style="width: 200px; height: 200px;">
                    <canvas id="thuChiChart"></canvas>
                </div>
            </div>
            <div class="card-footer bg-white">
                <div class="small mb-2">
                    <div class="fw-bold text-primary mb-1">Tổng năm @ViewBag.NamHienTai:</div>
                    <div class="d-flex justify-content-between">
                        <span>Tiền Thu:</span> <span class="text-success fw-bold">@string.Format("{0:N0}", ViewBag.ThuNamNay)</span>
                    </div>
                    <div class="d-flex justify-content-between mt-1">
                        <span>Tiền Chi:</span> <span class="text-danger fw-bold">@string.Format("{0:N0}", ViewBag.ChiNamNay)</span>
                    </div>
                </div>
                <hr class="my-2 border-dashed" style="border-top: 1px dashed #ccc;" />
                <div class="small">
                    <div class="fw-bold text-muted mb-1">Tháng này so với tháng trước:</div>
                    <div class="d-flex justify-content-between">
                        <span>Tiền Thu:</span>
                        <span>
                            @if (ViewBag.PhanTramThu > 0)
                            {<span class="text-success fw-bold">▲ Tăng @ViewBag.PhanTramThu%</span> }
                        else if (ViewBag.PhanTramThu < 0)
                        { <span class="text-danger fw-bold">▼ Giảm @Math.Abs(ViewBag.PhanTramThu)%</span> }
                    else
                    { <span class="text-muted">- Không đổi</span>}
                        </span>
                    </div>
                    <div class="d-flex justify-content-between mt-1">
                        <span>Tiền Chi:</span>
                        <span>
                            @if (ViewBag.PhanTramChi > 0)
                            {<span class="text-danger fw-bold">▲ Tăng @ViewBag.PhanTramChi%</span> }
                        else if (ViewBag.PhanTramChi < 0)
                        { <span class="text-success fw-bold">▼ Giảm @Math.Abs(ViewBag.PhanTramChi)%</span> }
                    else
                    { <span class="text-muted">- Không đổi</span>}
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow h-100 border-0">
            <div class="card-header bg-dark text-white">
                <h6 class="mb-0">Cơ cấu Chi tiêu tháng này</h6>
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <div style="width: 200px; height: 200px;">
                    <canvas id="danhMucChart"></canvas>
                </div>
            </div>
            @{
                string topDM = "Chưa có";
                if (ViewBag.DataGoc != null)
                {
                    var dmMax = ((IEnumerable<QuanLyChiTieu.Models.GiaoDich>)ViewBag.DataGoc)
                        .Where(x => x.LoaiGiaoDich == "Chi")
                        .GroupBy(x => x.DanhMuc)
                        .OrderByDescending(g => g.Sum(x => x.SoTien))
                        .Select(g => g.Key)
                        .FirstOrDefault();
                    if (!string.IsNullOrEmpty(dmMax)) topDM = dmMax;
                }
            }
            <div class="card-footer bg-white text-center small py-2.5">
                <span class="text-muted">Khoản chi tốn kém nhất:</span> <span class="fw-bold text-danger">@topDM</span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow h-100 border-0">
            <div class="card-header bg-dark text-white">
                <h6 class="mb-0">Biến động Chi tiêu theo tháng</h6>
            </div>
            <div class="card-body">
                <div style="height: 250px;">
                    <canvas id="soSanhThangChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4 border-0 bg-white">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-end mb-2">
            <div>
                <span class="text-muted fw-bold d-inline-flex align-items-center">
                    Hạn mức chi tiêu Tháng @ViewBag.ThangHienTai:
                    <button class="btn btn-sm btn-fintech ms-3 fw-bold d-inline-flex align-items-center shadow-sm"
                            onclick="moPopupHanMuc(@ViewBag.HanMucThang)">
                        <i class="fa-solid fa-sliders" style="margin-right: 6px;"></i> Thiết lập
                    </button>
                </span>
                <h5 class="mb-0 text-dark mt-2 fw-bold">
                    @string.Format("{0:N0}", ViewBag.ChiThangNay) <span class="text-muted fs-6">/ @string.Format("{0:N0}", ViewBag.HanMucThang) VNĐ</span>
                </h5>
            </div>
            <div class="text-end">
                @{
                    string textClass = "text-success";
                    if (ViewBag.PhanTramHanMuc >= 100) textClass = "text-danger";
                    else if (ViewBag.PhanTramHanMuc >= 80) textClass = "text-warning";
                }
                <span class="fw-bold fs-4 @textClass">
                    @ViewBag.PhanTramHanMuc%
                </span>
            </div>
        </div>

        <div class="progress shadow-sm" style="height: 16px;">
            @{
                string bgClass = "bg-success";
                if (ViewBag.PhanTramHanMuc >= 100) bgClass = "bg-danger";
                else if (ViewBag.PhanTramHanMuc >= 80) bgClass = "bg-warning";

                double percentWidth = ViewBag.PhanTramHanMuc > 100 ? 100 : ViewBag.PhanTramHanMuc;
                string cssWidth = percentWidth.ToString(System.Globalization.CultureInfo.InvariantCulture) + "%";
            }
            <div class="progress-bar progress-bar-striped progress-bar-animated @bgClass"
                 role="progressbar"
                 style="width: @cssWidth;"
                 aria-valuenow="@ViewBag.PhanTramHanMuc"
                 aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>

        @if (ViewBag.PhanTramHanMuc >= 100)
        {
            <small class="text-danger mt-2 d-block fw-bold">
                Cảnh báo: Bạn đã chi tiêu vượt quá hạn mức cho phép của tháng này!
            </small>
        }
        else if (ViewBag.PhanTramHanMuc >= 80)
        {
            <small class="text-warning mt-2 d-block fw-bold" style="color: #fd7e14 !important;">
                Lưu ý: Sắp chạm ngưỡng giới hạn chi tiêu trong tháng!
            </small>
        }
    </div>
</div>

<h4 class="mb-3 fw-bold" id="khu-vuc-lich-su" style="scroll-margin-top: 90px;">
    Lịch sử thu/chi
</h4>

<div class="card mb-3 shadow-sm border-0 bg-light">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Từ ngày</label>
                    <input type="date" name="tuNgay" value="@ViewBag.TuNgay" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Đến ngày</label>
                    <input type="date" name="denNgay" value="@ViewBag.DenNgay" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Loại</label>
                    <select name="loaiGiaoDich" class="form-select form-select-sm">
                        <option value="">Tất cả</option>
                        <option value="Chi" selected="@(ViewBag.LoaiGiaoDich == "Chi" ? "selected" : null)">Chi</option>
                        <option value="Thu" selected="@(ViewBag.LoaiGiaoDich == "Thu" ? "selected" : null)">Thu</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small">Tìm kiếm danh mục / Ghi chú</label>
                    <input type="text" name="tuKhoa" value="@ViewBag.TuKhoa" class="form-control form-control-sm" placeholder="Nhập từ khóa..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label small">Hiển thị</label>
                    <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="10" selected="@(ViewBag.PageSize == 10 ? "selected" : null)">10 dòng</option>
                        <option value="20" selected="@(ViewBag.PageSize == 20 ? "selected" : null)">20 dòng</option>
                        <option value="30" selected="@(ViewBag.PageSize == 30 ? "selected" : null)">30 dòng</option>
                        <option value="50" selected="@(ViewBag.PageSize == 50 ? "selected" : null)">50 dòng</option>
                    </select>
                </div>

                <div class="col-md-1 text-end">
                    <button type="submit" class="btn btn-sm btn-primary w-100">Lọc</button>
                </div>
            </div>
        </form>
    </div>
</div>

<table class="table table-bordered table-striped table-hover align-middle shadow-sm bg-white">
    <thead class="table-dark">
        <tr>
            <th>Ngày</th>
            <th>Loại</th>
            <th>Danh mục</th>
            <th>Số tiền (VNĐ)</th>
            <th>Ghi chú</th>
            <th class="text-center" style="width: 150px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NgayGiaoDich.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @if (item.LoaiGiaoDich == "Thu")
                    {
                        <span class="badge bg-success">@item.LoaiGiaoDich</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">@item.LoaiGiaoDich</span>
                    }
                </td>
                <td>@item.DanhMuc</td>
                <td class="text-end fw-bold">@item.SoTien.ToString("N0")</td>
                <td>@item.GhiChu</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                       onclick="xacNhanXoa(event, this.href)">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (ViewBag.TongSoTrang > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TongSoTrang; i++)
            {
                <li class="page-item @(i == ViewBag.TrangHienTai ? "active" : "")">
                    <a class="page-link" href="?trang=@i&tuNgay=@ViewBag.TuNgay&denNgay=@ViewBag.DenNgay&loaiGiaoDich=@ViewBag.LoaiGiaoDich&tuKhoa=@ViewBag.TuKhoa&pageSize=@ViewBag.PageSize">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<div class="modal fade" id="modalCreateGiaoDich" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white py-2">
                <h6 class="modal-title mb-0"><i class="fa-solid fa-plus me-2"></i>Thêm Giao Dịch Mới</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <ul class="nav nav-tabs mb-3 small fw-bold" id="tabThemGiaoDich" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="giao-dich-don-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#giao-dich-don" data-target="#giao-dich-don" type="button" role="tab">
                            <i class="fa-solid fa-file-invoice me-1"></i> Giao dịch đơn lẻ
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link text-danger" id="chi-phi-co-dinh-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#chi-phi-co-dinh" data-target="#chi-phi-co-dinh" type="button" role="tab">
                            <i class="fa-solid fa-list-check me-1"></i> Chi phí cố định tháng
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="giao-dich-don" role="tabpanel">
                        <form asp-action="Create" method="post">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-muted">Loại giao dịch</label>
                                    <select name="LoaiGiaoDich" class="form-select form-select-sm" required>
                                        <option value="Chi">Chi tiêu</option>
                                        <option value="Thu">Thu nhập</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-muted">Danh mục</label>
                                    <input type="text" name="DanhMuc" list="danhSachMasterDM" class="form-control form-control-sm" placeholder="Chọn hoặc gõ mới..." autocomplete="off" required />
                                    <datalist id="danhSachMasterDM">
                                        @{
                                            var listMaster = ViewBag.DanhSachDanhMuc as List<string>;
                                            if (listMaster != null)
                                            {
                                                foreach (var dm in listMaster)
                                                {
                                                    <option value="@dm"></option>
                                                }
                                            }
                                        }
                                    </datalist>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-muted">Số tiền (VNĐ)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="text" class="form-control text-end fw-bold text-primary input-tien-te" placeholder="0" autocomplete="off" required />
                                        <input type="hidden" name="SoTien" class="hidden-tien-te" value="0" />
                                        <span class="input-group-text p-1 small" style="font-size:0.75rem">đ</span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-muted">Ngày thực hiện</label>
                                    <input type="datetime-local" name="NgayGiaoDich" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" class="form-control form-control-sm" required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-bold text-muted">Ghi chú</label>
                                    <textarea name="GhiChu" class="form-control form-control-sm" rows="2" placeholder="Nhập mô tả thêm..."></textarea>
                                </div>

                                <div class="col-12 mt-2">
                                    <div class="form-check form-switch p-2.5 bg-light rounded border">
                                        <input class="form-check-input ms-0 me-2" type="checkbox" name="LaDinhKy" id="chkLaDinhKy" value="true">
                                        <label class="form-check-label small fw-bold text-primary" for="chkLaDinhKy">
                                            <i class="fa-solid fa-rotate me-1"></i> Tự động lặp lại định kỳ hàng tháng
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="text-end mt-3 pt-2 border-top">
                                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-sm btn-primary fw-bold px-3">Lưu giao dịch</button>
                            </div>
                        </form>
                    </div>

                    <div class="tab-pane fade" id="chi-phi-co-dinh" role="tabpanel">
                        <p class="text-muted small mb-3 italic"><i class="fa-solid fa-info-circle text-info"></i> Nhập số tiền vào các khoản bạn đã chi. Ô nào để trống hoặc gõ 0 sẽ tự bỏ qua.</p>

                        <form asp-action="CreateBulk" method="post">
                            <div class="bg-light p-3 rounded border" style="max-height: 280px; overflow-y: auto;">
                                @{
                                    var danhMucCoDinh = new List<string> { "Tiền thuê nhà", "Tiền điện", "Tiền nước", "Tiền Internet", "Tiền chung cư / Dịch vụ", "Tiền gửi xe", "Tiền rác / Vệ sinh" };
                                    for (int i = 0; i < danhMucCoDinh.Count; i++)
                                    {
                                        <div class="row mb-2 align-items-center">
                                            <div class="col-5 fw-bold text-dark small">@danhMucCoDinh[i]</div>
                                            <div class="col-7">
                                                <input type="hidden" name="danhSachGiaoDich[@i].DanhMuc" value="@danhMucCoDinh[i]" />
                                                <input type="hidden" name="danhSachGiaoDich[@i].LoaiGiaoDich" value="Chi" />
                                                <input type="hidden" name="danhSachGiaoDich[@i].NgayGiaoDich" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                                <input type="hidden" name="danhSachGiaoDich[@i].GhiChu" value="Chi phí cố định tháng" />

                                                <div class="input-group input-group-sm">
                                                    <input type="text" class="form-control text-end fw-bold text-danger input-tien-te" placeholder="0" autocomplete="off" />
                                                    <input type="hidden" name="danhSachGiaoDich[@i].SoTien" class="hidden-tien-te" value="0" />
                                                    <span class="input-group-text p-1 small" style="font-size:0.75rem">đ</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="text-end mt-3 pt-2 border-top">
                                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-sm btn-danger fw-bold px-3">Lưu gói chi phí</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalHanMuc" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form id="formHanMuc" asp-action="CapNhatHanMuc" asp-controller="Home" method="post">
                <div class="modal-header bg-primary text-white py-2">
                    <h6 class="modal-title mb-0"><i class="fa-solid fa-sliders me-2"></i>Thiết lập Hạn mức</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-3">
                    <label class="form-label small fw-bold text-muted">Số tiền giới hạn 1 tháng (VNĐ):</label>
                    <div class="input-group input-group-sm mt-1">
                        <input type="text" id="txtHanMucInput" class="form-control fw-bold text-primary text-end input-tien-te" placeholder="0" autocomplete="off" />
                        <input type="hidden" name="hanMucMoi" class="hidden-tien-te" id="hiddenHanMucVal" value="0" />
                        <span class="input-group-text p-1 small" style="font-size:0.75rem">đ</span>
                    </div>
                </div>
                <div class="modal-footer py-1 bg-light">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-sm btn-primary fw-bold px-3">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.12/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.12/dist/sweetalert2.all.min.js"></script>

<script>
    // BẮN POPUP KHI UPDATE THÀNH CÔNG
    document.addEventListener("DOMContentLoaded", function () {
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            Swal.fire({
                title: 'Thành công!',
                text: '@Html.Raw(TempData["SuccessMessage"])',
                icon: 'success',
                confirmButtonColor: '#198754',
                confirmButtonText: 'Đóng'
            });
            </text>
        }
    });

    function moPopupThemGiaoDich() {
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            try {
                let modalEl = document.getElementById('modalCreateGiaoDich');
                let myModal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                myModal.show();
                return;
            } catch (e) { }
        }
        try { $('#modalCreateGiaoDich').modal('show'); } catch (e) { }
    }

    function moPopupHanMuc(soGoc) {
        $('#hiddenHanMucVal').val(soGoc);
        $('#txtHanMucInput').val(soGoc === 0 ? '' : soGoc.toLocaleString('vi-VN'));

        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            try {
                let modalEl = document.getElementById('modalHanMuc');
                let myModal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                myModal.show();
                return;
            } catch (e) { }
        }
        try { $('#modalHanMuc').modal('show'); } catch (e) { }
    }

    $(document).on('click', '.modal [data-bs-dismiss="modal"], .modal [data-dismiss="modal"]', function () {
        let modalEl = $(this).closest('.modal')[0];
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            try { let b5Modal = bootstrap.Modal.getInstance(modalEl); if (b5Modal) b5Modal.hide(); } catch (e) { }
        }
        try { $(modalEl).modal('hide'); } catch (e) { }
    });

    // 1. CHART THU CHI (Doughnut)
    const tongThu = @(ViewBag.TongThu ?? 0);
    const tongChi = @(ViewBag.TongChi ?? 0);

    if (tongThu > 0 || tongChi > 0) {
        const ctx = document.getElementById('thuChiChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: { labels: ['Tổng Thu', 'Tổng Chi'], datasets: [{ data: [tongThu, tongChi], backgroundColor: ['#198754', '#dc3545'], borderWidth: 1 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });
    }

    // 2. CHART CƠ CẤU DANH MỤC CHI (Pie Chart)
    const dmLabels = [];
    const dmData = [];
    const dmColors = ['#fc5c65', '#fd9644', '#fed330', '#2bcbba', '#45aaf2', '#4b7bec', '#a55eea', '#778ca3', '#20bf6b', '#eb3b5a'];

    @{
        if (ViewBag.DataGoc != null)
        {
            var dsDm = ((IEnumerable<QuanLyChiTieu.Models.GiaoDich>)ViewBag.DataGoc)
                .Where(x => x.LoaiGiaoDich == "Chi")
                .GroupBy(x => string.IsNullOrEmpty(x.DanhMuc) ? "Khác" : x.DanhMuc)
                .Select(g => new { DM = g.Key, Tong = g.Sum(x => x.SoTien) })
                .OrderByDescending(x => x.Tong)
                .ToList();

            foreach(var item in dsDm)
            {
                <text>
                dmLabels.push('@Html.Raw(item.DM)');
                dmData.push(@item.Tong);
                </text>
            }
        }
    }

    if (dmData.length > 0) {
        const ctxDm = document.getElementById('danhMucChart').getContext('2d');
        new Chart(ctxDm, {
            type: 'pie',
            data: { labels: dmLabels, datasets: [{ data: dmData, backgroundColor: dmColors.slice(0, dmData.length), borderWidth: 1 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } } }
        });
    } else {
        document.getElementById('danhMucChart').parentNode.innerHTML = "<span class='text-muted small'>Chưa có dữ liệu chi tiêu</span>";
    }

    // 3. CHART BIẾN ĐỘNG THEO THÁNG
    const thangLabels = []; const thangDataThu = []; const thangDataChi = [];

    @{
        if(Model != null && ViewBag.DataGoc != null)
        {
            var dataThang = ((IEnumerable<QuanLyChiTieu.Models.GiaoDich>)ViewBag.DataGoc)
                 .GroupBy(g => new { g.NgayGiaoDich.Year, g.NgayGiaoDich.Month })
            .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month)
            .Select(g => new {
                TenThang = $"Tháng {g.Key.Month}/{g.Key.Year}",
                TongThu = g.Where(x => x.LoaiGiaoDich == "Thu").Sum(x => x.SoTien),
                TongChi = g.Where(x => x.LoaiGiaoDich == "Chi").Sum(x => x.SoTien)
            }).ToList();

            foreach(var item in dataThang)
            {
                <text>
                thangLabels.push('@Html.Raw(item.TenThang)'); thangDataThu.push(@item.TongThu); thangDataChi.push(@item.TongChi);
                </text>
            }
        }
    }

    if (thangLabels.length > 0) {
        const ctxBar = document.getElementById('soSanhThangChart').getContext('2d');
        new Chart(ctxBar, {
            type: 'bar',
            data: {
                labels: thangLabels,
                datasets: [
                    { label: 'Tổng Thu', data: thangDataThu, backgroundColor: 'rgba(25, 135, 84, 0.7)', borderColor: '#198754', borderWidth: 1, borderRadius: 4 },
                    { label: 'Tổng Chi', data: thangDataChi, backgroundColor: 'rgba(220, 53, 69, 0.7)', borderColor: '#dc3545', borderWidth: 1, borderRadius: 4 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false, plugins: { legend: { display: true, position: 'bottom' } },
                scales: { y: { beginAtZero: true, ticks: { callback: function(value) { return (value / 1000000).toLocaleString('vi-VN') + ' Tr'; } } } }
            }
        });
    }

    function xacNhanXoa(e, url) {
        e.preventDefault();
        Swal.fire({
            title: 'Bạn có chắc chắn?', text: "Dữ liệu này sẽ bị xóa vĩnh viễn!", icon: 'warning',
            showCancelButton: true, confirmButtonColor: '#dc3545', cancelButtonColor: '#6c757d',
            confirmButtonText: 'Đồng ý!', cancelButtonText: 'Hủy bỏ'
        }).then((result) => { if (result.isConfirmed) window.location.href = url; });
    }

    // =========================================================================
    // LOGIC "MÚA DẤU CHẤM" BẤT TỬ (CHỈ TÌM TRONG PHẠM VI .INPUT-GROUP)
    // =========================================================================
    $(document).on('input', '.input-tien-te', function () {
        let raw = $(this).val().replace(/[^0-9]/g, '');
        let val = raw ? parseInt(raw, 10) : 0;

        // 1. Cập nhật mặt văn bản hiển thị (Ví dụ: "3.500.000")
        $(this).val(val === 0 ? '' : val.toLocaleString('vi-VN'));

        // 2. Chép con số nguyên thô (3500000) gán đè đúng vào thẻ hidden nằm cùng 1 block input-group
        $(this).closest('.input-group').find('.hidden-tien-te').val(val);
    });

    $(document).on('focus', '.input-tien-te', function () {
        if ($(this).val() === '0') $(this).val('');
    });

    $(document).on('blur', '.input-tien-te', function () {
        if ($(this).val() === '') {
            $(this).closest('.input-group').find('.hidden-tien-te').val('0');
        }
    });

    document.addEventListener("DOMContentLoaded", function () {
        const url = window.location.search;
        if (url.includes("loaiGiaoDich") || url.includes("pageSize") || url.includes("tuKhoa") || url.includes("trang") || url.includes("tuNgay")) {
            const mienLichSu = document.getElementById("khu-vuc-lich-su");
            if (mienLichSu) mienLichSu.scrollIntoView({ behavior: "smooth" });
        }
    });
</script>