<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white text-center py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-shield-halved me-2"></i>XÁC MINH OTP</h5>
            </div>
            <div class="card-body p-4">
                <p class="text-muted text-center small">Mã xác thực đã được gửi vào Email của bạn. Vui lòng kiểm tra và nhập vào ô dưới đây.</p>
                <form asp-action="VerifyOTP" method="post">
                    <input type="hidden" name="username" value="@ViewBag.Username" />
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-center d-block">Nhập mã số gồm 6 chữ số</label>
                        <input type="text" name="otp" class="form-control text-center fw-bold fs-4 letter-spacing-3" maxlength="6" required autocomplete="off" placeholder="------" />
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold py-2 mb-2">XÁC NHẬN MÃ</button>
                </form>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    @if (ViewBag.Error != null) { <text>Swal.fire({ title: 'Lỗi số OTP!', text: '@Html.Raw(ViewBag.Error)', icon: 'error', confirmButtonColor: '#dc3545' });</text> }
</script>