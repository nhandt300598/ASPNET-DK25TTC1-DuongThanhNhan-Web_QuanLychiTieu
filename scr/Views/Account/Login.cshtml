@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" /> 
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> 
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: #f4f6f9;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 400px;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <button id="btn-theme-toggle-login" class="btn btn-outline-secondary btn-sm shadow-sm" 
        style="position: fixed; top: 20px; right: 20px; z-index: 1000;" 
        title="Chuyển chế độ Sáng/Tối">
    <i class="fa-solid fa-moon" id="theme-icon-login"></i>
</button>
    <div class="card shadow login-card border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h4 class="mb-0 fw-bold">HỆ THỐNG QUẢN LÝ TÀI CHÍNH</h4>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center py-2 small fw-bold">@ViewBag.Error</div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted">Tài khoản</label>
                    <input type="text" name="username" class="form-control" placeholder="Nhập tài khoản..." required autofocus />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu..." required />
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">
                    ĐĂNG NHẬP
                </button>

                <div class="text-center mt-3">
                    <a asp-action="ForgotPassword" asp-controller="Account" class="text-decoration-none small text-muted">
                        Quên mật khẩu tài khoản?
                    </a>
                </div>
            </form>
            <hr class="my-4 border-secondary border-opacity-25" />

            <div class="text-center">
                <span class="small text-muted d-block mb-2">Chưa có tài khoản?</span>
                <a asp-action="Register" asp-controller="Account" class="btn btn-outline-primary w-100 fw-bold py-2 shadow-sm">
                    <i class="fa-solid fa-user-plus me-1"></i> ĐĂNG KÝ TÀI KHOẢN
                </a>
            </div>

        </div>
    </div>
    
   <script>
    document.addEventListener("DOMContentLoaded", function() {
        const themeToggleBtn = document.getElementById('btn-theme-toggle-login');
        const themeIcon = document.getElementById('theme-icon-login');
        const htmlElement = document.documentElement;

       
        const currentTheme = localStorage.getItem('theme');
        if (currentTheme === 'dark') {
            htmlElement.setAttribute('data-theme', 'dark');
            document.body.style.backgroundColor = '#121212'; 
            if (themeIcon) {
                themeIcon.classList.remove('fa-moon');
                themeIcon.classList.add('fa-sun');
            }
        }

        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                let theme = htmlElement.getAttribute('data-theme');

                if (theme === 'dark') {
                    htmlElement.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'light');
                    document.body.style.backgroundColor = ''; 
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                } else {
                    htmlElement.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                    document.body.style.backgroundColor = '#121212'; 
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                }
            });
        }
    });
</script>
</body>
 
</html>