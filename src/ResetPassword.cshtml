<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0">
            <div class="card-header bg-success text-white text-center py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-key me-2"></i>ĐẶT LẠI MẬT KHẨU</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="ResetPassword" method="post">
                    <input type="hidden" name="username" value="@ViewBag.Username" />
                    <input type="hidden" name="otp" value="@ViewBag.OTP" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Mật khẩu mới</label>
                        <input type="password" name="newPassword" class="form-control" required placeholder="Nhập mật khẩu mới..." />
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Xác nhận lại mật khẩu</label>
                        <input type="password" name="confirmPassword" class="form-control" required placeholder="Nhập lại mật khẩu mới..." />
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold py-2 mb-2">CẬP NHẬT MẬT KHẨU MỚI</button>
                </form>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    @if (ViewBag.Error != null) { <text>Swal.fire({ title: 'Lỗi!', text: '@Html.Raw(ViewBag.Error)', icon: 'error', confirmButtonColor: '#dc3545' });</text> }
    @if (ViewBag.Success != null) {
        <text>
        Swal.fire({ title: 'Thành công!', text: '@Html.Raw(ViewBag.Success)', icon: 'success', confirmButtonColor: '#198754' }).then(() => {
            window.location.href = '@Url.Action("Login", "Account")';
        });
        </text>
    }
</script>