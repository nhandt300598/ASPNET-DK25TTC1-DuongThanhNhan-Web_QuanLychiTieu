@model IEnumerable<QuanLyChiTieu.Models.DanhMuc>

@{
    ViewData["Title"] = "Cấu hình Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="mb-0 fw-bold"><i class="fa-solid fa-tags me-2 text-primary"></i>Quản lý Danh mục thu chi</h2>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary shadow-sm">
        <i class="fa-solid fa-arrow-left me-1"></i> Về Trang chủ
    </a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 bg-white">
            <div class="card-header bg-primary text-white fw-bold py-3">
                <i class="fa-solid fa-plus me-1"></i> TẠO DANH MỤC MỚI
            </div>
            <div class="card-body p-3">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Thuộc loại giao dịch</label>
                        <select name="loaiGiaoDich" class="form-select fw-bold">
                            <option value="Chi" class="text-danger">Chi (Tiền ra)</option>
                            <option value="Thu" class="text-success">Thu (Tiền vào)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Tên danh mục</label>
                        <input type="text" name="tenDanhMuc" class="form-control" required placeholder="VD: Tiền học cho con, Cà phê..." autocomplete="off" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">
                        Lưu vào danh sách
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0 bg-white">
            <div class="card-header bg-dark text-white fw-bold py-3">
                <i class="fa-solid fa-list me-1"></i> DANH SÁCH DANH MỤC ĐANG CÓ
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Tên danh mục</th>
                            <th>Phân loại</th>
                            <th>Quyền sở hữu</th>
                            <th class="text-center" style="width:100px;">Hủy</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-dark">@item.TenDanhMuc</td>
                                <td>
                                    <span class="badge @(item.LoaiGiaoDich == "Thu" ? "bg-success" : "bg-danger")">
                                        @item.LoaiGiaoDich
                                    </span>
                                </td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.TaiKhoan))
                                    {
                                        <span class="badge bg-secondary"><i class="fa-solid fa-globe me-1"></i>Danh mục chung</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark"><i class="fa-solid fa-user me-1"></i>Của riêng bạn</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.TaiKhoan))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger border-0" title="Xóa">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Mặc định</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>